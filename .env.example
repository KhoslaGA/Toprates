# ─────────────────────────────────────────────────────────────
# Sanity CMS — required in every environment
# ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_SANITY_PROJECT_ID=your_project_id_here
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2024-10-01

# Read token (optional, used for draft preview mode)
SANITY_API_READ_TOKEN=your_read_token_here

# Write token (ONLY for running scripts/seed.ts — never commit, never ship to client)
SANITY_WRITE_TOKEN=your_write_token_here

# ─────────────────────────────────────────────────────────────
# Site
# ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://toprates.ca
